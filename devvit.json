{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "mcp0n",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": ["0nmcp.com", "pwujhhmlrtxjmjzyttwn.supabase.co"]
    },
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "moderator"
    }
  },
  "menu": {
    "items": [
      {
        "label": "Create a new post",
        "description": "mcp0n",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Example form",
        "description": "Show a simple form",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/example-form"
      }
    ]
  },
  "forms": {
    "exampleForm": "/internal/form/example-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onPostCreate": "/internal/triggers/on-post-create",
    "onCommentCreate": "/internal/triggers/on-comment-create"
  },
  "scheduler": {
    "tasks": {
      "scan": {
        "endpoint": "/internal/jobs/scan",
        "cron": "*/30 * * * *"
      },
      "generate": {
        "endpoint": "/internal/jobs/generate",
        "cron": "0 */2 * * *"
      },
      "post": {
        "endpoint": "/internal/jobs/post",
        "cron": "0 */4 * * *"
      },
      "track": {
        "endpoint": "/internal/jobs/track",
        "cron": "0 * * * *"
      }
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  }
}
